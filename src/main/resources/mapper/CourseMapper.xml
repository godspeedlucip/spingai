<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.main.demo.Mapper.CourseMapper">

    <select id="query" resultType="com.main.demo.entity.po.Course">
        select * from course
        <where>
            <if test="type != null">
                and type = #{type}
            </if>
            <if test="edu != null">
                and edu &lt;= #{edu}
            </if>
        </where>
        <if test="sorts != null and sorts.size > 0">
            ORDER BY
            <foreach collection="sorts" item="sort" separator=",">
                <choose>
                    <when test="sort.field == 'price'"> price </when>
                    <when test="sort.field == 'duration'"> duration </when>
                    <otherwise> id </otherwise>
                </choose>
                <choose>
                    <when test="sort.order == 'asc' or sort.order == 'ASC'"> ASC </when>
                    <otherwise> DESC </otherwise>
                </choose>
            </foreach>
        </if>
    </select>

    <select id="queryAll" resultType="com.main.demo.entity.po.Course">
        select * from course
    </select>

</mapper>
